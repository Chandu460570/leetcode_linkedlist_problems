class Solution(object):
    def removeNthFromEnd(self, head, n):
        """
        :type head: Optional[ListNode]
        :type n: int
        :rtype: Optional[ListNode]
        """
        fast=head
        slow=head

        for _ in range(n):
            fast = fast.next
        
        if fast is None:
            return head.next

        while fast.next != None:
            fast=fast.next
            slow=slow.next

        slow.next = slow.next.next
    
        return head
