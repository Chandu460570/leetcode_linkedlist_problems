# Definition for singly-linked list.
# class ListNode(object):
#     def __init__(self, val=0, next=None):
#         self.val = val
#         self.next = next
class Solution(object):
    def middleNode(self, head):
        """
        :type head: Optional[ListNode]
        :rtype: Optional[ListNode]
        """
        if not head:
            return head
        
        fast = head
        slow = head
        while fast and slow:
            if fast.next:
                fast = fast.next
                if fast.next:
                    fast = fast.next
                else:
                    return slow.next
            else:
                return slow
            if slow.next:
                slow = slow.next
